%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 1200 760
%%HiResBoundingBox: 0 0 1200 760
%%LanguageLevel: 2
%%Pages: 1
%%EndComments

/m { moveto } bind def
/l { lineto } bind def
/cp { closepath } bind def
/f { fill } bind def
/s { stroke } bind def
/rgb { setrgbcolor } bind def
/gs { gsave } bind def
/gr { grestore } bind def

/courtBLX 115 def
/courtBLY 105 def
/courtBRX 1085 def
/courtBRY 105 def
/courtTRX 990 def
/courtTRY 635 def
/courtTLX 210 def
/courtTLY 635 def

/mapPoint {
  /v exch 100 div def
  /u exch 100 div def
  /omu 1 u sub def
  /omv 1 v sub def
  /px
    omu omv mul courtBLX mul
    u omv mul courtBRX mul add
    u v mul courtTRX mul add
    omu v mul courtTLX mul add
  def
  /py
    omu omv mul courtBLY mul
    u omv mul courtBRY mul add
    u v mul courtTRY mul add
    omu v mul courtTLY mul add
  def
  px py
} def

/lm { mapPoint moveto } bind def
/ll { mapPoint lineto } bind def

/quadPath {
  /inset exch def
  newpath
  inset inset lm
  100 inset sub inset ll
  100 inset sub 100 inset sub ll
  inset 100 inset sub ll
  cp
} def

/logicLine {
  newpath
  4 -2 roll lm
  ll
} def

/logicDot {
  /r exch def
  /cy exch def
  /cx exch def
  newpath
  0 1 32 {
    /i exch def
    /ang i 11.25 mul def
    /px cx r ang cos mul add def
    /py cy r ang sin mul add def
    i 0 eq { px py lm } { px py ll } ifelse
  } for
  cp
} def

/logicArcStroke {
  /steps exch def
  /a2 exch def
  /a1 exch def
  /ry exch def
  /rx exch def
  /cy exch def
  /cx exch def
  newpath
  0 1 steps {
    /i exch def
    /ang a1 a2 a1 sub i steps div mul add def
    /px cx rx ang cos mul add def
    /py cy ry ang sin mul add def
    i 0 eq { px py lm } { px py ll } ifelse
  } for
  s
} def

/courtPoly {
  newpath
  0 0 lm
  100 0 ll
  100 100 ll
  0 100 ll
  cp
} def

1 setlinejoin
1 setlinecap

